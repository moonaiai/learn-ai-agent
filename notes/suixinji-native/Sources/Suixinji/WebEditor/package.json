{
  "name": "suixinji-web-editor",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && mkdir -p dist && cp src/index.html dist/index.html && cp src/style.css dist/style.css && ./node_modules/esbuild/bin/esbuild src/main.js --bundle --minify --format=iife --outfile=dist/editor.js"
  },
  "dependencies": {
    "@tiptap/core": "2.27.2",
    "@tiptap/extension-font-family": "2.27.2",
    "@tiptap/extension-image": "2.27.2",
    "@tiptap/extension-table": "2.27.2",
    "@tiptap/extension-table-cell": "2.27.2",
    "@tiptap/extension-table-header": "2.27.2",
    "@tiptap/extension-table-row": "2.27.2",
    "@tiptap/extension-text-style": "2.27.2",
    "@tiptap/pm": "2.27.2",
    "@tiptap/starter-kit": "2.27.2",
    "esbuild": "0.25.0"
  }
}
